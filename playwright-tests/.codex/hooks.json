{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$TOOL_INPUT\" | findstr /i \"--no-verify\" >NUL && echo BLOCKED: --no-verify is not allowed && exit /b 2 || exit /b 0"
          }
        ],
        "description": "Block git hook-bypass flag"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$TOOL_INPUT\" | findstr /i /r \"\\<rm\\>.*-rf\\>|--force|--hard\" >NUL && echo BLOCKED: Destructive command detected && exit /b 2 || exit /b 0"
          }
        ],
        "description": "Block destructive shell commands"
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo Session started at %DATE% %TIME%>> .codex\\session.log"
          }
        ],
        "description": "Log session start time"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo PreCompact at %DATE% %TIME%>> .codex\\session.log"
          }
        ],
        "description": "Log pre-compact event"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo Session ended at %DATE% %TIME%>> .codex\\session.log"
          }
        ],
        "description": "Log session end time"
      }
    ]
  }
}
